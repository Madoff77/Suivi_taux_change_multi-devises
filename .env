# =============================================================================
# .env - parametres injectes dans docker-compose.yaml
# Ce fichier evite tout hardcoding d'identifiants dans le DAG.
# =============================================================================

# ---- Utilisateur admin de l'UI Airflow (http://localhost:8080) ----
_AIRFLOW_WWW_USER_USERNAME=airflow
_AIRFLOW_WWW_USER_PASSWORD=airflow

# ---- Connexion Airflow vers la base metier (Connection ID: exchange_postgres) ----
# Format URI Airflow ; pointe vers le service Docker "postgres-exchange".
AIRFLOW_CONN_EXCHANGE_POSTGRES=postgresql://exchange:exchange@postgres-exchange:5432/exchange_rates

# ---- Variables Airflow metier (injectees au demarrage) ----
AIRFLOW_VAR_EXCHANGE_RATE_PAIRS=[{"base":"EUR","target":"USD"},{"base":"EUR","target":"GBP"},{"base":"EUR","target":"JPY"},{"base":"USD","target":"CHF"},{"base":"GBP","target":"USD"}]
AIRFLOW_VAR_EXCHANGE_RATE_ALERT_THRESHOLD_PCT=1.5
AIRFLOW_VAR_EXCHANGE_RATE_FRESHNESS_THRESHOLD_HOURS=24
